parameters:
	ignoreErrors:
		-
			message: "#^Method Controllers\\\\AccueilController\\:\\:index\\(\\) has no return type specified\\.$#"
			count: 1
			path: src/Controllers/AccueilController.php

		-
			message: "#^Method Controllers\\\\ChatController\\:\\:generate_request\\(\\) has no return type specified\\.$#"
			count: 1
			path: src/Controllers/ChatController.php

		-
			message: "#^Method Controllers\\\\ChatController\\:\\:generate_request\\(\\) has parameter \\$context with no value type specified in iterable type array\\.$#"
			count: 1
			path: src/Controllers/ChatController.php

		-
			message: "#^Access to an undefined property Controllers\\\\LoginController\\:\\:\\$authService\\.$#"
			count: 3
			path: src/Controllers/LoginController.php

		-
			message: "#^Access to an undefined static property Core\\\\Controller\\:\\:\\$viewsPath\\.$#"
			count: 2
			path: src/Core/Controller.php

		-
			message: "#^Property Core\\\\Router\\:\\:\\$routes type has no value type specified in iterable type array\\.$#"
			count: 1
			path: src/Core/Router.php
