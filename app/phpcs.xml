<?xml version="1.0"?>
<ruleset name="I-AMU">
    <description>PSR-12 with project-specific lenience.</description>

    <!-- Scanned roots (relative to this file = app/). -->
    <file>src</file>
    <file>public</file>
    <file>tests</file>

    <!-- Process .php files only. -->
    <arg name="extensions" value="php"/>

    <!-- Friendly output. -->
    <arg name="colors"/>
    <arg value="sp"/>

    <!-- Base ruleset. -->
    <rule ref="PSR12"/>

    <!-- Line length: PSR-12 recommends 120, we keep that. -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="160"/>
        </properties>
    </rule>
</ruleset>
